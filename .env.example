# HuggingFace
HF_TOKEN=hf_your_token_here
# Note: Mistral-7B-Instruct requires HF PRO ($9/mo) for reliable access

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key

# SEC EDGAR (max 10 req/sec — violation = IP ban)
EDGAR_USER_AGENT="stockSentimentAnalysis/1.0 your@email.com"

# Pipeline tuning
MAX_ARTICLES_PER_RUN=50
MINHASH_THRESHOLD=0.72
HIGH_SEVERITY_THRESHOLD=0.7

# Model IDs
FINBERT_MODEL_ID=ProsusAI/finbert
MISTRAL_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.2
EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2

# HF API retry config
HF_API_RETRIES=3
HF_API_BACKOFF_BASE=2.0
ENTITY_SIMILARITY_THRESHOLD=0.72
